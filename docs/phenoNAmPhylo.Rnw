\begin{figure}[h!]
    \centering
     \includegraphics[width=\textwidth]{..//..//pheno_bc/figures/phyloClade.pdf}
     \caption{Tree (denoted with an asterisk) and shrub species differences were accounted for by including phylogenetic effects on the intercept of a model estimating days to budburst after the start of forcing treatments (simplified to `days' here). This approach estimated a phylogenetic scaling parameter for the intercept of \Sexpr{lamT} (where values close to one indicate a phylogenetic effect consistent with Brownian motion and values close to zero the absence such an effect). Included for each tip of the phylogeny is the species-level intercept value in brackets, along with the names of major the clades represented in the tree.\\ } 
    \label{fig:phylo}
\end{figure}

